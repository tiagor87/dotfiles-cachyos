// custom — variantes xkb que combinam layouts existentes.
//
// libxkbcommon (usado pelo niri) inclui ~/.config/xkb como include path
// além do padrão do sistema (/usr/share/X11/xkb). Este arquivo é linkado
// para ~/.config/xkb/symbols/custom por desktop/install/8-keyboard.sh.

// us(intl) usa o modelo genérico (pc105) e por isso não define símbolo para
// a tecla <AB11> — a tecla extra "/ ?" do ABNT2, entre AltGr e as setas.
// Essa tecla só é mapeada pelo layout br(basic) (ver /usr/share/X11/xkb/symbols/br).
// Esta variante reaproveita o us(intl) e acrescenta o símbolo do br(basic)
// só para <AB11>, preservando a tecla física em um teclado ABNT2.
xkb_symbols "us_abnt2" {
    include "us(intl)"
    name[Group1]= "English (US, international AltGr dead keys, ABNT2 slash key)";
    key <AB11> { [ slash, question, degree, questiondown ] };
};
